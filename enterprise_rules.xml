<!--
  Wazuh - Enterprise Security Rules
  Version: 2.0
  Source: enterprise_rules.xml + audit reviews from 2026-06-01 22:26 and 22:30 CEST
  ID Range: 100600-101099

  Audit conclusions implemented:
  - Existing detections were kept where possible because the source rules were known to work.
  - Noisy single-event AD/cloud detections were downgraded to base signals.
  - Volume/correlation rules were added for Kerberoasting, DNS tunneling, brute force and bulk download.
  - same_source_ip was replaced with same_srcip or same_field where practical.
  - MITRE mapping was corrected for BEC forwarding rules and web shells.
  - Added missing high-value Windows, PowerShell, Linux FIM, ransomware and persistence detections.

  Operational notes:
  - Validate field names with wazuh-logtest against archives.json before production use.
  - Tune CDB allowlists for admin hosts, service accounts, VPN ranges, CDN/EDR domains and known SPNs.
-->
<group name="enterprise,security,attack">

  <!-- BLOK 01: INITIAL ACCESS / OFFICE / WEB -->

  <rule id="100600" level="8">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(winword|excel|powerpnt)\.exe.*\/(macro|vba|auto|xlm)</field>
    <description>INITIAL ACCESS [T1566.001]: Office macro-related command line - base signal</description>
    <mitre><id>T1566.001</id></mitre>
    <group>enterprise,initial_access,office,</group>
  </rule>

  <rule id="100601" level="14">
    <if_sid>60009</if_sid>
    <field name="win.eventdata.parentProcessName" type="pcre2">(?i)(winword|excel|powerpnt|onenote)\.exe$</field>
    <field name="win.eventdata.processName" type="pcre2">(?i)(cmd|powershell|pwsh|wscript|cscript|mshta|regsvr32|rundll32)\.exe$</field>
    <description>INITIAL ACCESS [T1204.002/T1059]: Office spawned shell or script host</description>
    <mitre><id>T1204.002</id><id>T1059</id></mitre>
    <group>enterprise,initial_access,office,critical,</group>
  </rule>

  <rule id="100602" level="13">
    <if_group>web</if_group>
    <field name="data.url" type="pcre2">(?i)(\.php\?cmd=|\/shell\.php|\/c99\.php|\/r57\.php|\/webshell|cmd\.exe\?|\/eval\.php)</field>
    <description>INITIAL ACCESS/PERSISTENCE [T1190/T1505.003]: Web shell access indicator</description>
    <mitre><id>T1190</id><id>T1505.003</id></mitre>
    <group>enterprise,initial_access,webshell,</group>
  </rule>

  <rule id="100603" level="10">
    <if_group>web</if_group>
    <field name="data.url" type="pcre2">(?i)(\/\.git\/|\/\.env|\/config\.php\.bak|\/wp-config\.php\.bak|\/\.htpasswd)</field>
    <description>INITIAL ACCESS [T1190]: Sensitive file exposure attempt</description>
    <mitre><id>T1190</id></mitre>
    <group>enterprise,initial_access,web,</group>
  </rule>

  <rule id="100604" level="13">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\bmshta\.exe\b.*(https?:|vbscript:|javascript:)</field>
    <description>INITIAL ACCESS [T1218.005]: MSHTA remote script execution</description>
    <mitre><id>T1218.005</id></mitre>
    <group>enterprise,initial_access,lolbas,</group>
  </rule>

  <rule id="101001" level="13">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.parentProcessName" type="pcre2">(?i)(w3wp|httpd|apache|nginx|php-cgi|tomcat|java)\.exe$</field>
    <field name="win.eventdata.processName" type="pcre2">(?i)(cmd|powershell|pwsh|sh|bash|python|perl|nc|ncat)\.exe?$</field>
    <description>INITIAL ACCESS [T1505.003/T1059]: Web server process spawned shell/interpreter</description>
    <mitre><id>T1505.003</id><id>T1059</id></mitre>
    <group>enterprise,initial_access,webshell,critical,</group>
  </rule>

