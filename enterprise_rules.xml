<!--
  Wazuh - Enterprise Security Rules
  Version: 1.0 (zrekonstruowana z poprzednich wdrożeń)
  ID Range: 100600-101499
  Pokrycie: 18 kategorii ATT&CK / MITRE
  Kategorie: Initial Access, AMSI, WMI, UAC, DCSync, Kerberoasting,
             AS-REP, ADCS, BloodHound, Pass-the-Hash/Ticket,
             C2 Frameworks, DNS Tunneling, BEC, Linux, Supply Chain,
             Insider Threat, Credential Access, Lateral Movement
  Compliance: GDPR/RODO, NIST 800-53, PCI DSS, ISO 27001, CIS v8, NIS2
-->
<group name="enterprise,security,attack">

  <!-- ============================================================
       BLOK 01: INITIAL ACCESS (T1566, T1190, T1189)
       ID: 100600-100614
       ============================================================ -->

  <rule id="100600" level="13">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(winword|excel|powerpnt)\.exe.*\/(macro|vba|auto|xlm)</field>
    <description>INITIAL ACCESS [T1566.001]: Office application spawning suspicious child process (macro)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>enterprise,initial_access</group>
  </rule>

  <rule id="100601" level="14">
    <if_sid>60009</if_sid>
    <field name="win.eventdata.parentProcessName" type="pcre2">(?i)(winword|excel|powerpnt|onenote)\.exe$</field>
    <field name="win.eventdata.processName" type="pcre2">(?i)(cmd|powershell|wscript|cscript|mshta|regsvr32|rundll32)\.exe$</field>
    <description>INITIAL ACCESS [T1566.001]: Malicious macro - Office spawned shell process</description>
    <mitre><id>T1566.001</id></mitre>
    <group>enterprise,initial_access,critical</group>
  </rule>

  <rule id="100602" level="14">
    <if_group>web</if_group>
    <field name="data.url" type="pcre2">(?i)(\.php\?cmd=|\/shell\.php|\/c99\.php|\/r57\.php|\/webshell|cmd\.exe\?|\/eval\.php)</field>
    <description>INITIAL ACCESS [T1190]: Web shell access detected</description>
    <mitre><id>T1190</id></mitre>
    <group>enterprise,initial_access,webshell</group>
  </rule>

  <rule id="100603" level="12">
    <if_group>web</if_group>
    <field name="data.url" type="pcre2">(?i)(\/\.git\/|\/\.env|\/config\.php\.bak|\/wp-config\.php\.bak|\/\.htpasswd)</field>
    <description>INITIAL ACCESS [T1190]: Sensitive file exposure attempt (git/config leak)</description>
    <mitre><id>T1190</id></mitre>
    <group>enterprise,initial_access</group>
  </rule>

  <rule id="100604" level="13">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(mshta\.exe\s+https?:|mshta.*vbscript:|mshta.*javascript:)</field>
    <description>INITIAL ACCESS [T1189]: MSHTA remote script execution (living-off-the-land)</description>
    <mitre><id>T1189</id></mitre>
    <group>enterprise,initial_access,lolbas</group>
  </rule>

